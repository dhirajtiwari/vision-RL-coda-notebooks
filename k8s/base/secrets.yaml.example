# Copy to secrets.yaml (gitignored) or create via kubectl / GitHub Actions secrets.
# NEO4J_AUTH format: neo4j/<password>
apiVersion: v1
kind: Secret
metadata:
  name: diagnostics-secrets
type: Opaque
stringData:
  NEO4J_PASSWORD: "change-me-staging"
  NEO4J_AUTH: "neo4j/change-me-staging"
  # Production connector credentials (optional in staging)
  # CRM_API_TOKEN: ""
  # PIM_API_TOKEN: ""