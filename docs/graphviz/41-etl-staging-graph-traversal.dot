// ETL → staging → graph storage → multi-hop traversal for accurate diagnosis
// Narrative: docs/17-Enterprise-Landscape-Pipeline-and-Topology.md
digraph EtlStagingGraphTraversal {
  graph [
    rankdir=TB
    label="41 — ETL → Staging → Graph Store → Fast Multi-Hop Traversal\n(How knowledge becomes accurate, low-latency diagnosis)"
    labelloc=t
    fontsize=14
    fontname="Helvetica"
    bgcolor="white"
    pad=0.4
    nodesep=0.3
    ranksep=0.45
  ]
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=9]
  edge [fontname="Helvetica", fontsize=8, color="#455A64"]

  // ========== BAND A: ETL ==========
  subgraph cluster_a {
    label="A · Extract → Transform → Catalog (batch)"
    style="rounded,filled"
    color="#2E7D32"
    fillcolor="#E8F5E9"

    A1 [label="EXTRACT (parallel)\nconnectors.fetch()\nvia runtime.parallel_map\nmax_workers=etl_connector_max_workers", fillcolor="#A5D6A7"]
    A2 [label="TRANSFORM (serial, deterministic)\nOntologyBuilder.build_catalog_payload()\nPIM + FSM confidences + Claims resolutions\n+ warranty extensions + provenance{}", fillcolor="#81C784"]
    A3 [label="WRITE CATALOG\nenterprise_knowledge_catalog.json\nsynthetic_diagnosis_data.json\netl_batch_id + lineage JSONL", shape=note, fillcolor="#FFF9C4"]
    A1 -> A2 -> A3
  }

  // ========== BAND B: STAGING ==========
  subgraph cluster_b {
    label="B · Staging gates (orchestrator order)"
    style="rounded,filled"
    color="#EF6C00"
    fillcolor="#FFF3E0"

    B1 [label="1 · knowledge_etl\nrun_knowledge_etl(load_neo4j=…)", fillcolor="#FFCC80"]
    B2 [label="2 · smoke_validation\nrun_smoke_validation()\nenterprise_test_scenarios.json", fillcolor="#FFB74D"]
    B3 [label="3 · staging_promotion\nrun_staging_promotion(smoke_passed)\nBLOCK if smoke fails", fillcolor="#FFA726"]
    B1 -> B2 -> B3
    A3 -> B1 [style=dashed]
    A3 -> B3 [label="read catalog"]
  }

  // ========== BAND C: GRAPH MATERIALIZATION ==========
  subgraph cluster_c {
    label="C · Graph materialization (why traversal is fast)"
    style="rounded,filled"
    color="#1565C0"
    fillcolor="#E3F2FD"

    C1 [label="populate_graph(driver, catalog)\nCREATE CONSTRAINT unique ids\nMERGE nodes per entity\nMERGE relationships", fillcolor="#90CAF9"]
    C2 [label="Neo4j property graph\nIndex-backed unique keys\n(product_id, symptom_id, …)\nNative adjacency for multi-hop", shape=cylinder, fillcolor="#64B5F6", penwidth=2]
    C3 [label="Invalidate read caches\ninvalidate_all_named_caches()\nafter successful load", fillcolor="#BBDEFB"]
    B3 -> C1
    A3 -> C1 [style=dotted, label="ETL load path"]
    C1 -> C2 -> C3
  }

  // ========== BAND D: STORED TOPOLOGY (reasoning chain) ==========
  subgraph cluster_d {
    label="D · Stored reasoning topology (ontology instance edges)"
    style="rounded,filled"
    color="#00695C"
    fillcolor="#E0F2F1"

    D0 [label="Asset\nINSTANCE_OF / BOUND_TO_SKU", fillcolor="#80CBC4"]
    D1 [label="Product", fillcolor="#4DB6AC"]
    D2 [label="Symptom / ErrorCode", fillcolor="#FFD54F"]
    D3 [label="FailureMode", fillcolor="#81C784"]
    D4 [label="DiagnosticStep\nNEXT_STEP · CONFIRMS", fillcolor="#CE93D8"]
    D5 [label="Component\nIMPACTS_COMPONENT", fillcolor="#4FC3F7"]
    D6 [label="Part\nREQUIRES_PART · REALIZED_BY", fillcolor="#B0BEC5"]
    D7 [label="Claim / HistoricalResolution\nCONFIRMED · USED_PART", fillcolor="#FFAB91"]
    D0 -> D1 -> D2 -> D3
    D3 -> D4
    D3 -> D5 -> D6
    D3 -> D6
    D7 -> D3 [dir=back, style=dashed, label="precedent"]
    C2 -> D1 [style=invis]
  }

  // ========== BAND E: RUNTIME TRAVERSAL ==========
  subgraph cluster_e {
    label="E · Runtime path — low-latency accurate response"
    style="rounded,filled"
    color="#6A1B9A"
    fillcolor="#F3E5F5"

    E0 [label="POST /diagnose\nrate limit · concurrency slot\ninput guardrails", fillcolor="#E1BEE7"]
    E1 [label="CRM bind + warranty gate\ncrm_enrichment · warranty_eligibility", fillcolor="#E1BEE7"]
    E2 [label="LangGraph\ndetect_product → run_diagnosis\n→ format → escalate", fillcolor="#CE93D8"]
    E3 [label="graph_rag.diagnose()\n1 lexical/hybrid symptom match\n2 Cypher INDICATES paths\n3 reliability FMEA+Bayes rank\n4 diagnostic_engine tree\n5 parts_predictor multi-source", fillcolor="#F8BBD0", penwidth=2]
    E4 [label="JSON response\nranked FM · parts · tree\nconfidence · provenance\ngraph_subgraph", shape=note, fillcolor="#FFF9C4"]
    E0 -> E1 -> E2 -> E3 -> E4
  }

  C2 -> E3 [label="Bolt Cypher multi-hop\n(not full graph scan)", penwidth=2, color="#0D47A1"]
  D3 -> E3 [style=dashed, label="evidence edges"]

  // ========== BAND F: WHY ACCURATE ==========
  subgraph cluster_f {
    label="F · Accuracy & speed design points"
    style="rounded,filled"
    color="#37474F"
    fillcolor="#FAFAFA"
    F1 [label="Deterministic scoring\ngraph/reliability.py\nS×O×D + P(fm|symptoms)\nfrom graph counts & edge confidence", fillcolor="#EEEEEE"]
    F2 [label="Hot-path caches\nGET /graph/ontology\nGET /graph/product/{id}\nTTL memory or Redis", fillcolor="#EEEEEE"]
    F3 [label="Provenance honesty\nsource_system · doc URI\nsimulated flags on fixtures", fillcolor="#EEEEEE"]
  }
  E3 -> F1 [style=dotted]
  C3 -> F2 [style=dotted]
}
