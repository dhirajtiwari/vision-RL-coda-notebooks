// Figure 19: Production pipeline landscape — batch, governance, and runtime
digraph ProductionPipelines {
  graph [
    rankdir=TB
    label="Figure 19: Production Pipeline Landscape — Batch, Governance & Runtime"
    labelloc=t
    fontsize=14
    fontname="Arial"
    bgcolor="white"
    nodesep=0.35
  ]
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=9]
  edge [fontname="Arial", fontsize=8, color="#4472C4"]

  subgraph cluster_batch {
    label="Batch — Knowledge Engineering (scheduled)"
    bgcolor="#E2EFDA"
    style="filled,rounded"
    P1 [label="1. Knowledge ETL\n(full & incremental)", fillcolor="#C6E0B4"]
    P2 [label="2. Document Ingestion\n(PDF · FMEA · manuals)", fillcolor="#C6E0B4"]
    P3 [label="3. Data Quality &\nReconciliation", fillcolor="#C6E0B4"]
    P4 [label="4. Smoke / Regression\nValidation Gate", fillcolor="#FFF2CC"]
    P5 [label="5. Staging Promotion\n(approved batches only)", fillcolor="#FFF2CC"]
    P6 [label="6. Vector Index Build\n(optional hybrid RAG)", fillcolor="#E2EFDA"]
    P7 [label="7. Catalog Retirement\n(EOL products)", fillcolor="#E2EFDA"]
  }

  subgraph cluster_gov {
    label="Governance — Human-in-the-Loop"
    bgcolor="#FFF2CC"
    style="filled,rounded"
    G1 [label="8. SME Review &\nApproval Workflow"]
    G2 [label="9. Ontology Version\nMigration"]
    G3 [label="10. Lineage & Audit\nExport"]
  }

  subgraph cluster_ops {
    label="Operations — Platform Health"
    bgcolor="#FCE4D6"
    style="filled,rounded"
    O1 [label="11. Graph Backup &\nDR Snapshot"]
    O2 [label="12. Connector Health\n& Credential Rotation"]
  }

  subgraph cluster_feedback {
    label="Continuous Improvement"
    bgcolor="#D5E8F0"
    style="filled,rounded"
    F1 [label="13. Agent Override &\nFeedback Ingestion"]
    F2 [label="14. KPI / Telemetry\nAggregation"]
  }

  subgraph cluster_runtime {
    label="Runtime — Not batch pipelines (live services)"
    bgcolor="#BDD7EE"
    style="filled,rounded"
    R1 [label="Diagnosis API\nLangGraph + GraphRAG"]
    R2 [label="CRM / Warranty\nEnrichment"]
    R3 [label="Case Management\nHandoff"]
  }

  SRC [label="Enterprise Sources\nPIM · FSM · Claims · CRM · Docs", shape=component, fillcolor="#EDEDED"]
  STG [label="Staging Neo4j", shape=cylinder, fillcolor="#FCE4D6"]
  PRD [label="Production Neo4j", shape=cylinder, fillcolor="#F4B084"]

  SRC -> P1 -> P3 -> P4 -> STG
  SRC -> P2 -> P3
  P4 -> G1 -> P5 -> PRD
  P5 -> O1
  P6 -> PRD
  P7 -> PRD
  G2 -> P5
  G3 -> P1
  F1 -> G1
  F2 -> F1
  R1 -> PRD
  R2 -> R1
  R3 -> R1
}