# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Demo / diagnosis
DEMO_MODE=true
ALLOW_FIXTURE_FALLBACK=true
USE_HYBRID_SYMPTOM_MATCHING=true
ESCALATION_CONFIDENCE_THRESHOLD=0.65
SYMPTOM_MATCH_MIN_SCORE=0.30
ENABLE_PROVENANCE=true

# Operational persistence (escalations, CCaaS cases, claim submissions)
DATABASE_PATH=data/diagnostics.db

# Mock enterprise systems (default for local demo)
USE_MOCK_ENTERPRISE_APIS=true
MOCK_ENTERPRISE_API_URL=http://localhost:8090

# REST API
API_HOST=0.0.0.0
API_PORT=8080

# Admin API protection. Leave empty for the local demo (open /admin/* access).
# Set to a strong secret for ANY non-local deployment — every /admin/* request
# must then send a matching `X-Admin-Token` header.
# The frontend reads NEXT_PUBLIC_ADMIN_TOKEN (set it to the same value).
# ADMIN_API_TOKEN=change-me-to-a-strong-secret

# --- Guardrails (kickoff prompt §E) -----------------------------------------
RATE_LIMIT_PER_MINUTE=60           # per-client request budget (0 = disabled)
ENABLE_PII_REDACTION=true          # redact PII in logs/telemetry/responses
MAX_RESPONSE_CHARS=8000            # output length cap

# --- Observability / OpenTelemetry (§H) -------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true                      # structured JSON logs w/ correlation ids
OTEL_ENABLED=false                 # true to export spans/metrics via OTLP
OTEL_SERVICE_NAME=diagnostics-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
ENABLE_PROMETHEUS_METRICS=true     # expose /metrics endpoint

# --- LLM gateway (INACTIVE by default — §B/§G) ------------------------------
# Core diagnosis is deterministic. These enable the optional LLM path only.
LLM_ENABLED=false
LLM_PROVIDER=openai                # openai | azure_foundry
LLM_MODEL_ALIAS=diagnosis-rewriter # resolved via models/registry.yaml (pinned)
LLM_EXTRACT_MODEL=gpt-4o-mini      # cheapest model for optional unstructured extraction
# XAI_API_KEY=
# OPENAI_API_KEY=                  # secret — inject at runtime, never commit
# AZURE_OPENAI_API_KEY=            # Azure AI Foundry — secret
# AZURE_OPENAI_ENDPOINT=
#
# To enable the optional schema-bound unstructured extractor with the cheapest
# model (bulk/offline enrichment; core diagnosis stays deterministic):
#   export OPENAI_API_KEY=sk-...        # your OWN rotated key — never commit it
#   export LLM_ENABLED=true
#   export LLM_EXTRACT_MODEL=gpt-4o-mini
# It reads OPENAI_API_KEY from the environment only; the key is never stored.
# AZURE_OPENAI_API_VERSION=2024-10-21
# LLM_MODEL=grok-2-latest

# --- FinOps (§F) ------------------------------------------------------------
LLM_COST_BUDGET_USD_PER_DAY=5.00   # circuit-breaker ceiling for LLM path

# Production enterprise connector URLs (unset = use mock or local fixtures)
# CRM_API_URL=https://your-org.salesforce.com/services/data/v59.0
# CLAIMS_API_URL=https://claims.your-org.com/api/v1
# PIM_API_URL=https://pim.your-org.com/api
# FSM_API_URL=https://fsm.your-org.com/api/v2
